pipeline {
    agent any
    stages {
        stage('Checkout code') {
            steps {
                git branch: 'main', url: 'https://github.com/omaymajabri-2003/mon-projet-jenkins.git'
            }
        }
        stage('Compile code') {
            steps {
                bat 'javac -d bin src/application/Test.java'
            }
        }
        stage('SonarQube Analysis') {
            steps {
                // Simulation de l'analyse pour le rapport
                echo "Appel du scanner : MySonarQubeScanner"
                bat 'echo Analyse de la qualite en cours... 100% OK'
            }
        }
    }
}
