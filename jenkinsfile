pipeline {
    agent any

    stages {
        stage('Checkout code') {
            steps {
                // Jenkins télécharge votre code depuis votre GitHub
                git branch: 'main', url: 'https://github.com/omaymajabri-2003/mon-projet-jenkins.git'
            }
        }
        stage('Compile code') {
            steps {
                // On utilise 'bat' au lieu de 'sh' car vous êtes sur Windows
                bat 'javac -d bin src/application/Test.java'
            }
        }
        stage('Execute code') {
            steps {
                bat 'java -cp bin application.Test'
            }
        }
    }
}
