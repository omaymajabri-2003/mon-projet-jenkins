pipeline {
    agent any
    
    stages {
        stage('Checkout code') {
            steps {
                git branch: 'master', url: 'https://github.com/omaymajabri-2003/mon-projet-jenkins.git'
            }
        }
        
        // L'étape Build Maven a été supprimée car il n'y a pas de pom.xml
        
        stage('Build Dockerfile') {
            steps {
                // 1. Construction de l'image
                bat 'docker build . -t my-country-service:%BUILD_NUMBER%'
                
                // 2. Connexion à Docker Hub
                withCredentials([string(credentialsId: 'dockerhub-paswd', variable: 'dockerhubpwd')]) {
                    bat "docker login -u omaymaajabri -p %dockerhubpwd%"
                }
                
                // 3. Tag et Push
                bat 'docker tag my-country-service:%BUILD_NUMBER% omaymaajabri/my-country-service:%BUILD_NUMBER%'
                bat 'docker push omaymaajabri/my-country-service:%BUILD_NUMBER%'
            }
        }
        
        stage('Deploy microservice') {
            steps {
                bat '''
                docker rm -f country-service || exit 0
                docker run -d --name country-service omaymaajabri/my-country-service:%BUILD_NUMBER%
                '''
            }
        }
    }
}
